{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stocks-backtest-api-production-0c6a.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
